class Solution {
    private static final int MODULO = 1_000_000_007;
    private static long computePowerOfTwo(int exponent) {
        long result = 1;
        long currentBase = 2;
        
        while (exponent > 0) {
            if ((exponent & 1) == 1) {
                result = (result * currentBase) % MODULO;
            }
            currentBase = (currentBase * currentBase) % MODULO;
            exponent >>= 1;
        }
        
        return result;
    }

    //calculateMaxDepth function
    private static int calculateMaxDepth(int currentNode, int parentNode, List<Integer>[] adjacencyList) {
        int longestPath = 0;
        for (int neighbor : adjacencyList[currentNode]) {
            if (neighbor != parentNode) {
                int depthFromNeighbor = calculateMaxDepth(neighbor, currentNode, adjacencyList) + 1;
                longestPath = Math.max(longestPath, depthFromNeighbor);
            }
        }
        
        return longestPath;
    }

    //assignEdgeWeights function
    public int assignEdgeWeights(int[][] edges) {
        int totalNodes = edges.length + 1;
        List<Integer>[] adjacencyList = new ArrayList[totalNodes + 1];
        
        for (int i = 0; i <= totalNodes; i++) {
            adjacencyList[i] = new ArrayList<>();
        }
        
        for (int[] edge : edges) {
            int u = edge[0];
            int v = edge[1];
            adjacencyList[u].add(v);
            adjacencyList[v].add(u);
        }
        
        int targetExponent = calculateMaxDepth(1, 0, adjacencyList) - 1;
        return (int) computePowerOfTwo(targetExponent);
    }
}
