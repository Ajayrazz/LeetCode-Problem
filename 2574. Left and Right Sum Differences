class Solution {
    public int[] leftRightDifference(int[] nums) {
        if(nums == null || nums.length == 0) return nums;
        int n = nums.length;
        int[] left = new int[n];
        int left_sum = nums[0];
        left[0] = 0;
        for(int i = 1; i < n; i++){
            left[i] = left_sum;
            left_sum += nums[i];
        }

        int[] right = new int[n];
        right[n - 1] = 0;
        int right_sum = nums[n - 1];
        for(int i = n - 2; i >= 0; i--){
            right[i] = right_sum;
            right_sum += nums[i];
        }

        for(int i = 0; i < n; i++){
            nums[i] = Math.abs(left[i] - right[i]);
        }

        return nums;
    }
}
