class Solution {
    public int[] pathExistenceQueries(int n, int[] nums, int maxDiff, int[][] queries) {
        int[][] sortedNodes = new int[n][2];
        for (int i = 0; i < n; i++) {
            sortedNodes[i][0] = nums[i];
            sortedNodes[i][1] = i;
        }

        Arrays.sort(sortedNodes, (a, b) -> Integer.compare(a[0], b[0]));
        int[] sortedPosition = new int[n];
        for (int i = 0; i < n; i++) {
            sortedPosition[sortedNodes[i][1]] = i;
        }

        final int LOG = 18;
        int[][] jump = new int[n][LOG];
        int right = 0;
        for (int left = 0; left < n; left++) {
            right = Math.max(right, left);
            while (right + 1 < n &&
                    sortedNodes[right + 1][0] - sortedNodes[right][0] <=  maxDiff && sortedNodes[right + 1][0] - sortedNodes[left][0] <= maxDiff) {
                right++;
            }

            jump[left][0] = right;
        }

        for (int power = 1; power < LOG; power++) {
            for (int i = 0; i < n; i++) {
                jump[i][power] = jump[jump[i][power - 1]][power - 1];
            }
        }

        int[] answer = new int[queries.length];
        for (int i = 0; i < queries.length; i++) {
            int left = sortedPosition[queries[i][0]];
            int rightPos = sortedPosition[queries[i][1]];
            if (left > rightPos) {
                int temp = left;
                left = rightPos;
                rightPos = temp;
            }

            if (left == rightPos) {
                answer[i] = 0;
                continue;
            }

            int current = left;
            int steps = 0;
            for (int power = LOG - 1; power >= 0; power--) {
                if (jump[current][power] < rightPos) {
                    current = jump[current][power];
                    steps += (1 << power);
                }
            }

            if (jump[current][0] >= rightPos) {
                answer[i] = steps + 1;
            } else {
                answer[i] = -1;
            }
        }

        return answer;
    }
}
