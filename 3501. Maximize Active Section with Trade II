class MaxSegmentTree {
    private final int[] tree;
    private final int[] values;
    private final int size;

    public MaxSegmentTree(int[] nums) {
        values = nums;
        size = nums.length;
        tree = new int[size * 4];

        if (size > 0) {
            buildTree(1, 0, size - 1);
        }
    }

    private void buildTree(int node, int left, int right) {
        if (left == right) {
            tree[node] = values[left];
            return;
        }

        int mid = (left + right) / 2;

        buildTree(node * 2, left, mid);
        buildTree(node * 2 + 1, mid + 1, right);

        tree[node] = Math.max(tree[node * 2], tree[node * 2 + 1]);
    }

    public int rangeMax(int l, int r) {
        if (l > r) return 0;
        return query(1, 0, size - 1, l, r);
    }

    private int query(int node, int left, int right, int ql, int qr) {

        if (ql <= left && right <= qr) {
            return tree[node];
        }

        int mid = (left + right) / 2;
        int answer = 0;

        if (ql <= mid) {
            answer = Math.max(answer,
                    query(node * 2, left, mid, ql, qr));
        }

        if (qr > mid) {
            answer = Math.max(answer,
                    query(node * 2 + 1, mid + 1, right, ql, qr));
        }

        return answer;
    }
}

class Solution {

    public List<Integer> maxActiveSectionsAfterTrade(String s, int[][] queries) {

        int totalOnes = countOnes(s);

        List<Integer> zeroLength = new ArrayList<>();
        List<Integer> leftPos = new ArrayList<>();
        List<Integer> rightPos = new ArrayList<>();

        collectZeroBlocks(s, zeroLength, leftPos, rightPos);

        int blocks = zeroLength.size();

        List<Integer> result = new ArrayList<>();

        if (blocks < 2) {
            for (int i = 0; i < queries.length; i++) {
                result.add(totalOnes);
            }
            return result;
        }

        int[] adjacentSum = new int[blocks - 1];

        for (int i = 0; i < blocks - 1; i++) {
            adjacentSum[i] = zeroLength.get(i) + zeroLength.get(i + 1);
        }

        MaxSegmentTree tree = new MaxSegmentTree(adjacentSum);

        for (int[] q : queries) {

            int L = q[0];
            int R = q[1];

            int first = firstBlock(rightPos, L);
            int last = lastBlock(leftPos, R);

            if (first >= blocks || last < 0 || first >= last) {
                result.add(totalOnes);
                continue;
            }

            int firstContribution =
                    rightPos.get(first) -
                    Math.max(leftPos.get(first), L) + 1;

            int lastContribution =
                    Math.min(rightPos.get(last), R) -
                    leftPos.get(last) + 1;

            int gain;

            if (first + 1 == last) {

                gain = firstContribution + lastContribution;

            } else {

                int option1 =
                        firstContribution + zeroLength.get(first + 1);

                int option2 =
                        zeroLength.get(last - 1) + lastContribution;

                int option3 =
                        tree.rangeMax(first + 1, last - 2);

                gain = Math.max(option1,
                        Math.max(option2, option3));
            }

            result.add(totalOnes + gain);
        }

        return result;
    }

    private int countOnes(String s) {

        int cnt = 0;

        for (char ch : s.toCharArray()) {
            if (ch == '1') cnt++;
        }

        return cnt;
    }

    private void collectZeroBlocks(
            String s,
            List<Integer> len,
            List<Integer> left,
            List<Integer> right) {

        int n = s.length();
        int i = 0;

        while (i < n) {

            int start = i;

            while (i < n && s.charAt(i) == s.charAt(start)) {
                i++;
            }

            if (s.charAt(start) == '0') {
                len.add(i - start);
                left.add(start);
                right.add(i - 1);
            }
        }
    }

    private int firstBlock(List<Integer> ends, int target) {

        int lo = 0;
        int hi = ends.size();

        while (lo < hi) {

            int mid = (lo + hi) / 2;

            if (ends.get(mid) < target)
                lo = mid + 1;
            else
                hi = mid;
        }

        return lo;
    }

    private int lastBlock(List<Integer> starts, int target) {

        int lo = 0;
        int hi = starts.size();

        while (lo < hi) {

            int mid = (lo + hi) / 2;

            if (starts.get(mid) <= target)
                lo = mid + 1;
            else
                hi = mid;
        }

        return lo - 1;
    }
}
