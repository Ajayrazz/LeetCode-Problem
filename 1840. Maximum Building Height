class Solution {
    public int maxBuilding(int n, int[][] restrictions) {
        int len = restrictions.length;
        int[][] arr = new int[len + 2][2];
        arr[0][0] = 1;
        arr[0][1] = 0;

        for (int i = 0; i < len; i++) {
            arr[i + 1][0] = restrictions[i][0];
            arr[i + 1][1] = restrictions[i][1];
        }

        Arrays.sort(arr, 0, len + 1, (a, b) -> a[0] - b[0]);
        int total = len + 1;
        if (arr[total - 1][0] != n) {
            arr[total][0] = n;
            arr[total][1] = n - 1;
            total++;
        }

        for (int i = 1; i < total; i++) {
            int diff = arr[i][0] - arr[i - 1][0];
            arr[i][1] = Math.min(arr[i][1], arr[i - 1][1] + diff);
        }

        for (int i = total - 2; i >= 0; i--) {
            int diff = arr[i + 1][0] - arr[i][0];
            arr[i][1] = Math.min(arr[i][1], arr[i + 1][1] + diff);
        }

        long res = 0;
        int idx = 1;
        while (idx < total) {
            long left = arr[idx - 1][0], right = arr[idx][0], hLeft = arr[idx - 1][1], hRight = arr[idx][1], width = right - left, peak = (hLeft + hRight + width) / 2;

            if (peak > res) {
                res = peak;
            }

            idx++;
        }

        return (int) res;
    }
}
